{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "plan_slug",
    "plan_path",
    "phase",
    "repos",
    "tickets",
    "current",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "plan_slug": { "type": "string", "minLength": 1 },
    "plan_path": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["regular", "workspace", "unknown"] },
    "phase": {
      "type": "string",
      "enum": ["initialized", "ticket_loop", "final_review", "blocked", "failed", "paused", "complete"]
    },
    "repos": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["worktree", "head", "dirty"],
        "properties": {
          "worktree": { "type": "string", "minLength": 1 },
          "base": { "type": ["string", "null"] },
          "head": { "type": "string", "minLength": 1 },
          "branch": { "type": ["string", "null"] },
          "dirty": { "type": "boolean" }
        }
      }
    },
    "tickets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "target_repo", "title", "status", "attempt", "commit", "last_error", "updated_at"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "target_repo": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pending", "implementing", "auditing", "repairing", "audit_repairing", "committed", "blocked", "failed", "paused", "skipped"]
          },
          "stage": { "type": ["string", "null"] },
          "attempt": { "type": "integer", "minimum": 0 },
          "commit": { "type": ["string", "null"] },
          "log": { "type": ["string", "null"] },
          "last_error": { "type": ["string", "null"] },
          "updated_at": { "type": "string", "minLength": 1 }
        }
      }
    },
    "current": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "ticket_id": { "type": "string", "minLength": 1 },
        "stage": { "type": ["string", "null"] }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string" },
        "findings": { "type": "array" }
      }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
